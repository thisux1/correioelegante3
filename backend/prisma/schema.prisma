generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  email          String          @unique
  password       String
  messages       Message[]
  pages          Page[]
  assets         Asset[]
  consents       UserConsent[]
  refundRequests RefundRequest[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Message {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  message       String
  recipient     String
  mediaUrl      String?
  theme         String   @default("classic")
  status        String   @default("draft")
  visibility    String   @default("public")
  publishedAt   DateTime?
  paymentStatus   String   @default("pending")
  paymentId       String?
  paymentProvider String?  // "stripe" | "mercadopago"
  paymentMethod   String?  // "pix" | "credit_card" | "boleto"
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([paymentId])
  @@index([status, visibility])
}

model Page {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  content         Json
  status          String   @default("draft")
  visibility      String   @default("public")
  publishedAt     DateTime?
  paymentStatus   String   @default("pending")
  paymentId       String?
  paymentProvider String?
  paymentMethod   String?
  version         Int      @default(1)
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, paymentStatus])
  @@index([paymentId])
  @@index([status, visibility])
}

model Asset {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs             MediaJob[]
  kind             String
  source           String
  storageKey       String
  publicUrl        String?
  posterUrl        String?
  waveform         Json?
  mimeType         String
  sizeBytes        Int
  width            Int?
  height           Int?
  durationMs       Int?
  processingStatus String   @default("pending")
  errorCode        String?
  errorMessage     String?
  moderationStatus String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, kind])
  @@index([storageKey])
}

model MediaJob {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId       String   @db.ObjectId
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId        String   @db.ObjectId
  type          String
  status        String   @default("pending")
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)
  payload       Json?
  errorCode     String?
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@unique([assetId, type])
}

model UserConsent {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType String
  version      String
  acceptedAt   DateTime @default(now())

  @@index([userId])
  @@unique([userId, documentType, version])
}

model RefundRequest {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String
  resourceId   String
  reasonType   String
  reason       String?
  status       String   @default("requested")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, resourceType, resourceId, status])
}
